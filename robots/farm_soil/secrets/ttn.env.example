# Copy to ttn.env and fill in. The real ttn.env is gitignored.
TTN_BEARER_TOKEN=NNSXS.xxxxxxxxxxxxxxxx

# CIMIS Web API AppKey — register at cimis.water.ca.gov to obtain one.
CIMIS_APP_KEY=00000000-0000-0000-0000-000000000000

# Discord channel webhook — Server settings -> Integrations -> Webhooks
# -> New Webhook -> Copy URL. The URL itself is the auth token; treat
# as a secret (the gitignore here covers ttn.env, not this example file).
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/<id>/<token>
